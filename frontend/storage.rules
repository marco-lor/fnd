rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/(default)/documents/users/$(uid);
    }

    function isActiveUser(uid) {
      // Storage rules permit only two cross-service Firestore document reads;
      // the root pending marker blocks an in-flight deletion, and a missing
      // root fails closed after deletion. Firestore rules separately prevent
      // recreation whenever the durable deletion-job tombstone exists.
      return firestore.get(userDocPath(uid)).data.get("deletionState", null) != "pending";
    }

    function isActiveSignedIn() {
      return isSignedIn() && isActiveUser(request.auth.uid);
    }

    function userRole() {
      return isActiveSignedIn()
        ? firestore.get(userDocPath(request.auth.uid)).data.role
        : null;
    }

    function isDM() {
      return userRole() == "dm";
    }

    function isWebmaster() {
      return userRole() == "webmaster";
    }

    function isCatalogManager() {
      return isDM() || isWebmaster();
    }

    function filenameBelongsToCaller(fileName) {
      return isActiveSignedIn()
        && fileName.matches('^.*' + request.auth.uid + '.*$');
    }

    function isCallerOwnedVarieFile(fileName) {
      return isActiveSignedIn()
        && fileName.matches('^varie_' + request.auth.uid + '_.*$');
    }

    function isImage(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('^image/.+$');
    }

    function isAudio(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('^audio/.+$');
    }

    function isVideo(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('^video/.+$');
    }

    match /characters/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if filenameBelongsToCaller(fileName)
        && isImage(8 * 1024 * 1024);
      allow delete: if filenameBelongsToCaller(fileName) || isWebmaster();
    }

    match /items/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if (
          isCatalogManager()
          || isCallerOwnedVarieFile(fileName)
        )
        && isImage(8 * 1024 * 1024);
      allow delete: if isCatalogManager()
        || isCallerOwnedVarieFile(fileName);
    }

    match /tecnicas/videos/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if filenameBelongsToCaller(fileName)
        && isVideo(25 * 1024 * 1024);
      allow delete: if filenameBelongsToCaller(fileName);
    }

    match /tecnicas/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if filenameBelongsToCaller(fileName)
        && isImage(8 * 1024 * 1024);
      allow delete: if filenameBelongsToCaller(fileName);
    }

    match /spells/videos/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if (
          isCatalogManager()
          || filenameBelongsToCaller(fileName)
        )
        && isVideo(25 * 1024 * 1024);
      allow delete: if isCatalogManager() || filenameBelongsToCaller(fileName);
    }

    match /spells/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if (
          isCatalogManager()
          || filenameBelongsToCaller(fileName)
        )
        && isImage(8 * 1024 * 1024);
      allow delete: if isCatalogManager() || filenameBelongsToCaller(fileName);
    }

    match /spell_images/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isCatalogManager() && isImage(8 * 1024 * 1024);
      allow delete: if isCatalogManager();
    }

    match /spell_videos/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isCatalogManager() && isVideo(25 * 1024 * 1024);
      allow delete: if isCatalogManager();
    }

    match /foes/{allPaths=**} {
      allow read, write: if isDM();
    }

    match /echi_npcs/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isCatalogManager()
        && request.auth.uid == userId
        && isImage(8 * 1024 * 1024);
      allow delete: if isCatalogManager();
    }

    // Canonical Task 05 user-owned media. Metadata changes are committed by
    // callable functions before an old object is removed; these paths never
    // overlap shared catalog assets.
    match /users/{userId}/profile/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isActiveSignedIn()
        && request.auth.uid == userId
        && isImage(8 * 1024 * 1024);
      allow delete: if false;
    }

    match /users/{userId}/inventory/{inventoryId}/{fileName} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isCatalogManager());
      allow create, update: if isActiveSignedIn()
        && isActiveUser(userId)
        && (request.auth.uid == userId || isCatalogManager())
        && isImage(8 * 1024 * 1024);
      allow delete: if false;
    }

    match /users/{userId}/spells/{contentId}/{fileName} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isCatalogManager());
      allow create, update: if isActiveSignedIn()
        && isActiveUser(userId)
        && (request.auth.uid == userId || isCatalogManager())
        && (
          isImage(8 * 1024 * 1024)
          || isVideo(25 * 1024 * 1024)
        );
      allow delete: if false;
    }

    match /users/{userId}/tecniche/{contentId}/{fileName} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isCatalogManager());
      allow create, update: if isActiveSignedIn()
        && isActiveUser(userId)
        && (request.auth.uid == userId || isCatalogManager())
        && (
          isImage(8 * 1024 * 1024)
          || isVideo(25 * 1024 * 1024)
        );
      allow delete: if false;
    }

    match /grigliata/backgrounds/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isDM()
        && request.auth.uid == userId
        && (
          isImage(15 * 1024 * 1024)
          || isVideo(25 * 1024 * 1024)
        );
      allow delete: if isDM();
    }

    match /grigliata/music/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isDM()
        && request.auth.uid == userId
        && isAudio(25 * 1024 * 1024);
      allow delete: if isDM();
    }

    match /grigliata/tokens/{userId}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isDM());
      allow create, update: if isActiveSignedIn()
        && request.auth.uid == userId
        && isImage(8 * 1024 * 1024);
      allow delete: if (isActiveSignedIn() && request.auth.uid == userId) || isDM();
    }
  }
}
