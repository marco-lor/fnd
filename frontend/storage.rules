rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/(default)/documents/users/$(uid);
    }

    function isDM() {
      return isSignedIn()
        && firestore.exists(userDocPath(request.auth.uid))
        && firestore.get(userDocPath(request.auth.uid)).data.role == "dm";
    }

    function isProtectedGrigliataPath(path) {
      return path.matches('^grigliata/backgrounds(/.*)?$')
        || path.matches('^grigliata/music(/.*)?$')
        || path.matches('^grigliata/tokens(/.*)?$');
    }

    match /grigliata/backgrounds/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isDM();
    }

    match /grigliata/music/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isDM();
    }

    match /grigliata/tokens/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isDM());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if isSignedIn() && !isProtectedGrigliataPath(allPaths);
    }
  }
}
