// Firestore Security Rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userDeletionJobPath(uid) {
      return /databases/$(database)/documents/user_deletion_jobs/$(uid);
    }

    function hasUserDeletionTombstone(uid) {
      return exists(userDeletionJobPath(uid));
    }

    function isActiveUser(uid) {
      return exists(userDocPath(uid))
        && get(userDocPath(uid)).data.get("deletionState", null) != "pending"
        && !hasUserDeletionTombstone(uid);
    }

    function isActiveSignedIn() {
      return isSignedIn() && isActiveUser(request.auth.uid);
    }

    function authedCharacterId() {
      return isSignedIn() && exists(userDocPath(request.auth.uid))
        ? get(userDocPath(request.auth.uid)).data.characterId
        : null;
    }

    function isDM() {
      return isActiveSignedIn()
        && get(userDocPath(request.auth.uid)).data.role == "dm";
    }

    function isWebmaster() {
      return isActiveSignedIn()
        && get(userDocPath(request.auth.uid)).data.role == "webmaster";
    }

    function isPlayer() {
      return isActiveSignedIn()
        && (get(userDocPath(request.auth.uid)).data.role == "player"
            || get(userDocPath(request.auth.uid)).data.role == "players");
    }

    function isGrigliataManager() {
      return isDM();
    }

    function canReadPrivateUserDomain(userId) {
      return isSignedIn()
        && (request.auth.uid == userId || isDM() || isWebmaster());
    }

    function mapOrEmpty(data, fieldName) {
      return data.keys().hasAny([fieldName]) && data[fieldName] is map
        ? data[fieldName]
        : {};
    }

    function isValidUserDataRolloutStage(stage) {
      return stage in [
        "legacy-read",
        "shadow-verify",
        "dual-write",
        "new-read-dual-write",
        "new-only"
      ];
    }

    function isUserDataAggregateFrozen(userId) {
      let configPath = /databases/$(database)/documents/app_config/user_data_v2;
      let config = exists(configPath) ? get(configPath).data : {};
      let overrides = mapOrEmpty(config, "userOverrides");
      let globalStage = config.get("mode", config.get("stage", "legacy-read"));
      let configured = overrides.get(userId, globalStage);
      let stage = isValidUserDataRolloutStage(configured)
        ? configured
        : (isValidUserDataRolloutStage(globalStage) ? globalStage : "legacy-read");
      let drain = mapOrEmpty(config, "legacyDrain");
      let users = mapOrEmpty(drain, "users");
      let drainFieldMalformed = config.keys().hasAny(["legacyDrain"])
        && !(config.legacyDrain is map);
      let usersFieldMalformed = drain.keys().hasAny(["users"])
        && !(drain.users is map);
      return stage == "new-only"
        || drainFieldMalformed
        || (
          (
            overrides.keys().hasAny([userId])
            && isValidUserDataRolloutStage(overrides.get(userId, ""))
          )
            ? usersFieldMalformed || users.keys().hasAny([userId])
            : drain.keys().hasAny(["global"])
        );
    }

    function changesLegacyUserAggregate(nextData, existingData) {
      return nextData.diff(existingData).affectedKeys().hasAny([
        "stats",
        "Parametri",
        "AltriParametri",
        "flags",
        "inventory",
        "equipped",
        "beltCapacity",
        "slotCintura",
        "spells",
        "tecniche",
        "lingue",
        "conoscenze",
        "professioni",
        "active_turn_effect",
        "settings",
        "parameterLocks",
        "paramLocks",
        "drawColorKey",
        "shareLiveInteractions",
        "grigliataMuted",
        "hiddenGrigliataBackgrounds",
        "hiddenGrigliataTokens"
      ]);
    }

    function isAllowedUserDataRootMutation(userId, nextData, existingData) {
      return !isUserDataAggregateFrozen(userId)
        || (
          existingData.get("modelVersion", 0) == 2
          && nextData.get("modelVersion", 0) == 2
          && !changesLegacyUserAggregate(nextData, existingData)
        );
    }

    function stableMapField(nextMap, prevMap, fieldName) {
      return nextMap.get(fieldName, null) == prevMap.get(fieldName, null);
    }

    function isCharacterCreationOpen(data) {
      return mapOrEmpty(data, "flags").get("characterCreationDone", false) != true;
    }

    function hasStableStatsSystemFields(nextData, existingData) {
      let nextStats = mapOrEmpty(nextData, "stats");
      let existingStats = mapOrEmpty(existingData, "stats");
      return stableMapField(nextStats, existingStats, "level")
        && stableMapField(nextStats, existingStats, "hpTotal")
        && stableMapField(nextStats, existingStats, "manaTotal")
        && stableMapField(nextStats, existingStats, "essenzaTotal")
        && stableMapField(nextStats, existingStats, "basePointsAvailable")
        && stableMapField(nextStats, existingStats, "basePointsSpent")
        && stableMapField(nextStats, existingStats, "combatTokensAvailable")
        && stableMapField(nextStats, existingStats, "combatTokensSpent")
        && stableMapField(nextStats, existingStats, "negativeBaseStatCount");
    }

    function hasStableUserIdentityAndRole(nextData, existingData) {
      return nextData.get("role", null) == existingData.get("role", null)
        && nextData.get("email", null) == existingData.get("email", null)
        && nextData.get("created_at", null) == existingData.get("created_at", null)
        && nextData.get("createdAt", null) == existingData.get("createdAt", null)
        && !nextData.diff(existingData).affectedKeys().hasAny([
          "roleUpdatedAt",
          "roleUpdatedBy",
          "modelVersion",
          "summary",
          "deletionState",
          "deletionRequestedAt",
          "deletionRequestedBy"
        ]);
    }

    function isSafeOwnerUserCreate(userId) {
      return request.auth.uid == userId
        && !hasUserDeletionTombstone(userId)
        && !request.resource.data.keys().hasAny([
          "deletionState",
          "deletionRequestedAt",
          "deletionRequestedBy"
        ])
        && request.resource.data.get("role", null) == "player"
        && request.resource.data.get("email", "") is string
        && !request.resource.data.keys().hasAny(["roleUpdatedAt", "roleUpdatedBy"])
        // A frozen/new-only scope requires server-owned V2-first account
        // initialization. Direct client shell creation would leave the fixed
        // domain documents absent and cannot participate in the frozen sweep.
        && !isUserDataAggregateFrozen(userId);
    }

    function isSafeOwnerUserUpdate(userId) {
      return isActiveSignedIn()
        && request.auth.uid == userId
        && resource.data.get("deletionState", null) != "pending"
        && isAllowedUserDataRootMutation(
          userId,
          request.resource.data,
          resource.data
        )
        && hasStableUserIdentityAndRole(request.resource.data, resource.data)
        && (
          isCharacterCreationOpen(resource.data)
          || hasStableStatsSystemFields(request.resource.data, resource.data)
        );
    }

    function isSafePrivilegedUserUpdate(userId) {
      return (isDM() || isWebmaster())
        && resource.data.get("deletionState", null) != "pending"
        && isAllowedUserDataRootMutation(
          userId,
          request.resource.data,
          resource.data
        )
        && hasStableUserIdentityAndRole(request.resource.data, resource.data);
    }

    function grigliataTokenDocPath(tokenId) {
      return /databases/$(database)/documents/grigliata_tokens/$(tokenId);
    }

    function isGrigliataFoeTokenData(data) {
      return data.tokenType == "foe";
    }

    function isValidGrigliataTokenType(tokenType) {
      return tokenType in ["character", "custom", "foe"];
    }

    function isValidGrigliataTokenImageSource(imageSource) {
      return imageSource in ["profile", "uploaded", "foesHub"];
    }

    function isValidGrigliataCustomTokenRole(customTokenRole) {
      return customTokenRole in ["template", "instance"];
    }

    function isGrigliataTokenPendingDeletion(data) {
      return data is map
        && data.keys().hasAny(["task06Deletion"])
        && data.task06Deletion is map
        && data.task06Deletion.get("status", "") == "pending";
    }

    function resolveGrigliataCustomTokenRole(data) {
      return data.keys().hasAny(["customTokenRole"]) && data.customTokenRole is string
        ? data.customTokenRole
        : "template";
    }

    function resolveGrigliataCustomTemplateId(data, tokenId) {
      return data.keys().hasAny(["customTemplateId"])
          && data.customTemplateId is string
          && data.customTemplateId.size() > 0
        ? data.customTemplateId
        : tokenId;
    }

    function isValidGrigliataCustomTokenContract(data, tokenId) {
      let hasRole = data.keys().hasAny(["customTokenRole"]);
      let hasTemplateId = data.keys().hasAny(["customTemplateId"]);
      let resolvedRole = resolveGrigliataCustomTokenRole(data);
      let resolvedTemplateId = resolveGrigliataCustomTemplateId(data, tokenId);
      return (
        (
          (!hasRole && !hasTemplateId)
          || (
            hasRole
            && hasTemplateId
            && data.customTokenRole is string
            && isValidGrigliataCustomTokenRole(data.customTokenRole)
            && data.customTemplateId is string
            && data.customTemplateId.size() > 0
          )
        )
        && (
          (resolvedRole == "template" && resolvedTemplateId == tokenId)
          || (
            resolvedRole == "instance"
            && resolvedTemplateId != tokenId
            && resolvedTemplateId != data.ownerUid
          )
        )
      );
    }

    function isOwnerCreatableGrigliataCustomTokenProfile(data, tokenId) {
      return data.tokenType != "custom"
        || (
          resolveGrigliataCustomTokenRole(data) == "template"
          && resolveGrigliataCustomTemplateId(data, tokenId) == tokenId
        );
    }

    function isStableGrigliataCustomTokenContract(data, existingData, tokenId) {
      return data.tokenType != "custom"
        || (
          resolveGrigliataCustomTokenRole(data) == resolveGrigliataCustomTokenRole(existingData)
          && resolveGrigliataCustomTemplateId(data, tokenId) == resolveGrigliataCustomTemplateId(existingData, tokenId)
        );
    }

    function isValidGrigliataTokenProfile(data, tokenId) {
      return data.keys().hasAll([
          "ownerUid",
          "label",
          "imageUrl",
          "imagePath",
          "tokenType",
          "imageSource",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "ownerUid",
          "characterId",
          "label",
          "imageUrl",
          "imagePath",
          "tokenType",
          "customTokenRole",
          "customTemplateId",
          "imageSource",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy",
          "placed",
          "col",
          "row",
          "foeSourceId",
          "category",
          "rank",
          "dadoAnima",
          "notes",
          "stats",
          "Parametri",
          "spells",
          "tecniche"
        ])
        && data.ownerUid is string
        && data.label is string
        && data.imageUrl is string
        && data.imagePath is string
        && isValidGrigliataTokenType(data.tokenType)
        && isValidGrigliataTokenImageSource(data.imageSource)
        && (data.tokenType == "custom" || !data.keys().hasAny(["customTokenRole", "customTemplateId"]))
        && (!data.keys().hasAny(["characterId"]) || data.characterId is string)
        && (!data.keys().hasAny(["customTokenRole"]) || data.customTokenRole is string)
        && (!data.keys().hasAny(["customTemplateId"]) || data.customTemplateId is string)
        && (!data.keys().hasAny(["foeSourceId"]) || data.foeSourceId is string)
        && (!data.keys().hasAny(["category"]) || data.category is string)
        && (!data.keys().hasAny(["rank"]) || data.rank is string)
        && (!data.keys().hasAny(["dadoAnima"]) || data.dadoAnima is string)
        && (!data.keys().hasAny(["notes"]) || data.notes is string)
        && (!data.keys().hasAny(["stats"]) || data.stats is map)
        && (!data.keys().hasAny(["Parametri"]) || data.Parametri is map)
        && (!data.keys().hasAny(["spells"]) || data.spells is list)
        && (!data.keys().hasAny(["tecniche"]) || data.tecniche is list)
        && (!data.keys().hasAny(["createdBy"]) || data.createdBy == null || data.createdBy is string)
        && (data.updatedBy == null || data.updatedBy is string)
        && (
          (data.tokenType == "character" && tokenId == data.ownerUid && data.imageSource == "profile")
          || (
            data.tokenType == "custom"
            && tokenId != data.ownerUid
            && data.imageSource == "uploaded"
            && isValidGrigliataCustomTokenContract(data, tokenId)
          )
          || (
            data.tokenType == "foe"
            && tokenId != data.ownerUid
            && data.imageSource == "foesHub"
            && data.foeSourceId is string
            && data.foeSourceId.size() > 0
            && data.stats is map
            && data.Parametri is map
            && data.spells is list
            && data.tecniche is list
          )
        );
    }

    function isValidLegacyGrigliataTokenScrubUpdate(data, existingData) {
      return existingData is map
        && data.ownerUid == existingData.ownerUid
        && !data.keys().hasAny(["placed", "col", "row"])
        && data.diff(existingData).affectedKeys().hasOnly([
          "placed",
          "col",
          "row",
          "updatedAt",
          "updatedBy"
        ]);
    }

    function isGrigliataPlacementId(backgroundId, scopedId, placementId) {
      return backgroundId is string
        && scopedId is string
        && placementId == backgroundId + "__" + scopedId;
    }

    function resolveGrigliataPlacementTokenId(data) {
      return data.keys().hasAny(["tokenId"]) && data.tokenId is string && data.tokenId.size() > 0
        ? data.tokenId
        : data.ownerUid;
    }

    function getReferencedGrigliataTokenData(data) {
      let tokenId = resolveGrigliataPlacementTokenId(data);
      return tokenId is string
        && tokenId != data.ownerUid
        && exists(grigliataTokenDocPath(tokenId))
        ? get(grigliataTokenDocPath(tokenId)).data
        : null;
    }

    function isValidGrigliataPlacementTokenReference(data) {
      let tokenId = resolveGrigliataPlacementTokenId(data);
      let tokenData = getReferencedGrigliataTokenData(data);
      return tokenId is string
        && (
          tokenId == data.ownerUid
          || (
            tokenData != null
            && tokenData.ownerUid == data.ownerUid
            && (isGrigliataManager() || tokenData.tokenType != "foe")
          )
        );
    }

    function isValidGrigliataTurnEffect(effect) {
      return effect is map
        && effect.keys().hasAll([
          "id",
          "kind",
          "totalTurns",
          "remainingTurns",
          "appliesFromTurnCounter"
        ])
        && effect.keys().hasOnly([
          "id",
          "kind",
          "totalTurns",
          "remainingTurns",
          "appliesFromTurnCounter"
        ])
        && effect.id is string
        && effect.id.size() > 0
        && effect.kind is string
        && effect.kind.size() > 0
        && effect.totalTurns is int
        && effect.totalTurns > 0
        && effect.remainingTurns is int
        && effect.remainingTurns >= 0
        && effect.remainingTurns <= effect.totalTurns
        && effect.appliesFromTurnCounter is int
        && effect.appliesFromTurnCounter >= 0;
    }

    function hasValidGrigliataTurnEffects(effects) {
      return effects is list
        && effects.size() <= 12
        && (effects.size() < 1 || isValidGrigliataTurnEffect(effects[0]))
        && (effects.size() < 2 || isValidGrigliataTurnEffect(effects[1]))
        && (effects.size() < 3 || isValidGrigliataTurnEffect(effects[2]))
        && (effects.size() < 4 || isValidGrigliataTurnEffect(effects[3]))
        && (effects.size() < 5 || isValidGrigliataTurnEffect(effects[4]))
        && (effects.size() < 6 || isValidGrigliataTurnEffect(effects[5]))
        && (effects.size() < 7 || isValidGrigliataTurnEffect(effects[6]))
        && (effects.size() < 8 || isValidGrigliataTurnEffect(effects[7]))
        && (effects.size() < 9 || isValidGrigliataTurnEffect(effects[8]))
        && (effects.size() < 10 || isValidGrigliataTurnEffect(effects[9]))
        && (effects.size() < 11 || isValidGrigliataTurnEffect(effects[10]))
        && (effects.size() < 12 || isValidGrigliataTurnEffect(effects[11]));
    }

    function isValidOwnerManagedGrigliataTurnOrderCreate(data) {
      let hasJoinedAt = data.keys().hasAny(["turnOrderJoinedAt"]);
      let isInTurnOrder = data.keys().hasAny(["isInTurnOrder"]) && data.isInTurnOrder == true;

      return (
        !hasJoinedAt && !isInTurnOrder
      ) || (
        hasJoinedAt
        && isInTurnOrder
        && data.turnOrderJoinedAt == request.time
      );
    }

    function isValidOwnerManagedGrigliataTurnOrderUpdate(nextData, prevData) {
      let nextHasJoinedAt = nextData.keys().hasAny(["turnOrderJoinedAt"]);
      let prevHasJoinedAt = prevData.keys().hasAny(["turnOrderJoinedAt"]);
      let nextIsInTurnOrder = nextData.keys().hasAny(["isInTurnOrder"]) && nextData.isInTurnOrder == true;

      return (
        !nextHasJoinedAt && !nextIsInTurnOrder
      ) || (
        nextHasJoinedAt
        && nextIsInTurnOrder
        && (
          (!prevHasJoinedAt && nextData.turnOrderJoinedAt == request.time)
          || (prevHasJoinedAt && nextData.turnOrderJoinedAt == prevData.turnOrderJoinedAt)
        )
      );
    }

    function isValidGrigliataAoEFigureType(figureType) {
      return figureType in ["circle", "square", "cone", "rectangle"];
    }

    function isValidGrigliataAoEFigureSlot(slot) {
      return slot is int
        && slot >= 1
        && slot <= 5;
    }

    function isGrigliataAoEFigureId(backgroundId, ownerUid, figureType, slot, figureId) {
      return backgroundId is string
        && ownerUid is string
        && isValidGrigliataAoEFigureType(figureType)
        && isValidGrigliataAoEFigureSlot(slot)
        && figureId == backgroundId + "__" + ownerUid + "__" + figureType + "__" + string(slot);
    }

    function isOwnGrigliataAoEFigureProbeId(figureId) {
      return isSignedIn()
        && figureId is string
        && figureId.matches('^.+__' + request.auth.uid + '__(circle|square|cone|rectangle)__(1|2|3|4|5)$');
    }

    function isValidGrigliataPlacement(data, placementId) {
      return data.keys().hasAll([
          "backgroundId",
          "ownerUid",
          "col",
          "row",
          "isDead",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "backgroundId",
          "tokenId",
          "ownerUid",
          "label",
          "imageUrl",
          "col",
          "row",
          "sizeSquares",
          "isVisibleToPlayers",
          "isDead",
          "statuses",
          "visionEnabled",
          "visionRadiusSquares",
          "isInTurnOrder",
          "turnOrderInitiative",
          "turnOrderJoinedAt",
          "turnCounter",
          "turnEffects",
          "updatedAt",
          "updatedBy"
        ])
        && data.backgroundId is string
        && data.ownerUid is string
        && (!data.keys().hasAny(["tokenId"]) || data.tokenId is string)
        && (!data.keys().hasAny(["label"]) || data.label is string)
        && (!data.keys().hasAny(["imageUrl"]) || data.imageUrl is string)
        && data.col is int
        && data.row is int
        && (
          !data.keys().hasAny(["sizeSquares"])
          || (
            data.sizeSquares is int
            && data.sizeSquares >= 1
            && data.sizeSquares <= 9
          )
        )
        && (
          !data.keys().hasAny(["isVisibleToPlayers"])
          || data.isVisibleToPlayers is bool
        )
        && data.isDead is bool
        && (
          !data.keys().hasAny(["visionEnabled"])
          || data.visionEnabled is bool
        )
        && (
          !data.keys().hasAny(["visionRadiusSquares"])
          || (
            data.visionRadiusSquares is int
            && data.visionRadiusSquares >= 1
            && data.visionRadiusSquares <= 60
          )
        )
        && (
          !data.keys().hasAny(["isInTurnOrder"])
          || data.isInTurnOrder is bool
        )
        && (
          !data.keys().hasAny(["turnOrderInitiative"])
          || data.turnOrderInitiative is int
        )
        && (
          !data.keys().hasAny(["turnOrderJoinedAt"])
          || data.turnOrderJoinedAt is timestamp
        )
        && (
          !data.keys().hasAny(["turnCounter"])
          || (
            data.turnCounter is int
            && data.turnCounter >= 0
          )
        )
        && (
          !data.keys().hasAny(["turnEffects"])
          || hasValidGrigliataTurnEffects(data.turnEffects)
        )
        && (
          !data.keys().hasAny(["statuses"])
          || (
            data.statuses is list
            && data.statuses.size() <= 21
            && data.statuses.hasOnly([
              "bleeding",
              "blinded",
              "burning",
              "charmed",
              "concentrating",
              "crippled",
              "flying",
              "frightened",
              "frozen",
              "grappled",
              "hastened",
              "marked",
              "petrified",
              "poisoned",
              "prone",
              "restrained",
              "shielded",
              "silenced",
              "sleeping",
              "slowed",
              "stunned"
            ])
          )
        )
        && (data.updatedBy == null || data.updatedBy is string)
        && isGrigliataPlacementId(data.backgroundId, resolveGrigliataPlacementTokenId(data), placementId)
        && isValidGrigliataPlacementTokenReference(data);
    }

    function isValidGrigliataDrawColorKey(colorKey) {
      return colorKey in [
        "aurora-fuchsia",
        "ion-cyan",
        "nova-teal",
        "volt-lime",
        "solar-amber",
        "warp-violet"
      ];
    }

    function isValidGrigliataGridCell(cell) {
      return cell is map
        && cell.keys().hasAll(["col", "row"])
        && cell.keys().hasOnly(["col", "row"])
        && cell.col is int
        && cell.row is int;
    }

    function isValidGrigliataBoardPoint(point) {
      return point is map
        && point.keys().hasAll(["x", "y"])
        && point.keys().hasOnly(["x", "y"])
        && (point.x is int || point.x is float)
        && (point.y is int || point.y is float);
    }

    function isValidGrigliataAoEFigure(data, figureId) {
      return data.keys().hasAll([
          "backgroundId",
          "ownerUid",
          "figureType",
          "slot",
          "originCell",
          "targetCell",
          "colorKey",
          "isVisibleToPlayers",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "backgroundId",
          "ownerUid",
          "figureType",
          "slot",
          "originCell",
          "targetCell",
          "colorKey",
          "isVisibleToPlayers",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy",
          "showMeasurementDetails",
          "isFilled"
        ])
        && data.backgroundId is string
        && data.ownerUid is string
        && isValidGrigliataAoEFigureType(data.figureType)
        && isValidGrigliataAoEFigureSlot(data.slot)
        && isValidGrigliataGridCell(data.originCell)
        && isValidGrigliataGridCell(data.targetCell)
        && data.colorKey is string
        && isValidGrigliataDrawColorKey(data.colorKey)
        && data.isVisibleToPlayers is bool
        && (!data.keys().hasAny(["showMeasurementDetails"]) || data.showMeasurementDetails is bool)
        && (!data.keys().hasAny(["isFilled"]) || data.isFilled is bool)
        && (data.createdBy == null || data.createdBy is string)
        && (data.updatedBy == null || data.updatedBy is string)
        && isGrigliataAoEFigureId(data.backgroundId, data.ownerUid, data.figureType, data.slot, figureId);
    }

    function hasValidGrigliataAnchorCells(cells) {
      return cells is list
        && cells.size() > 0
        && cells.size() <= 16
        && (cells.size() < 1 || isValidGrigliataGridCell(cells[0]))
        && (cells.size() < 2 || isValidGrigliataGridCell(cells[1]))
        && (cells.size() < 3 || isValidGrigliataGridCell(cells[2]))
        && (cells.size() < 4 || isValidGrigliataGridCell(cells[3]))
        && (cells.size() < 5 || isValidGrigliataGridCell(cells[4]))
        && (cells.size() < 6 || isValidGrigliataGridCell(cells[5]))
        && (cells.size() < 7 || isValidGrigliataGridCell(cells[6]))
        && (cells.size() < 8 || isValidGrigliataGridCell(cells[7]))
        && (cells.size() < 9 || isValidGrigliataGridCell(cells[8]))
        && (cells.size() < 10 || isValidGrigliataGridCell(cells[9]))
        && (cells.size() < 11 || isValidGrigliataGridCell(cells[10]))
        && (cells.size() < 12 || isValidGrigliataGridCell(cells[11]))
        && (cells.size() < 13 || isValidGrigliataGridCell(cells[12]))
        && (cells.size() < 14 || isValidGrigliataGridCell(cells[13]))
        && (cells.size() < 15 || isValidGrigliataGridCell(cells[14]))
        && (cells.size() < 16 || isValidGrigliataGridCell(cells[15]));
    }

    function isValidGrigliataLiveInteraction(data, interactionId) {
      return data.keys().hasAll([
          "backgroundId",
          "ownerUid",
          "type",
          "source",
          "colorKey",
          "updatedAt",
          "updatedBy"
        ])
        && data.backgroundId is string
        && data.ownerUid is string
        && data.colorKey is string
        && isValidGrigliataDrawColorKey(data.colorKey)
        && (data.updatedBy == null || data.updatedBy is string)
        && isGrigliataPlacementId(data.backgroundId, data.ownerUid, interactionId)
        && (
          (
            data.type == "measure"
            && data.keys().hasAll(["anchorCells", "liveEndCell"])
            && data.keys().hasOnly([
              "backgroundId",
              "ownerUid",
              "type",
              "source",
              "colorKey",
              "anchorCells",
              "liveEndCell",
              "updatedAt",
              "updatedBy"
            ])
            && data.source in ["free", "token-drag"]
            && hasValidGrigliataAnchorCells(data.anchorCells)
            && isValidGrigliataGridCell(data.liveEndCell)
          )
          || (
            data.type == "aoe"
            && data.keys().hasAll(["figureType", "originCell", "targetCell"])
            && data.keys().hasOnly([
              "backgroundId",
              "ownerUid",
              "type",
              "source",
              "colorKey",
              "figureType",
              "originCell",
              "targetCell",
              "updatedAt",
              "updatedBy"
            ])
            && data.source in ["aoe-create", "aoe-move"]
            && isValidGrigliataAoEFigureType(data.figureType)
            && isValidGrigliataGridCell(data.originCell)
            && isValidGrigliataGridCell(data.targetCell)
          )
          || (
            data.type == "ping"
            && data.keys().hasAll(["point", "startedAtMs"])
            && data.keys().hasOnly([
              "backgroundId",
              "ownerUid",
              "type",
              "source",
              "colorKey",
              "point",
              "startedAtMs",
              "updatedAt",
              "updatedBy"
            ])
            && data.source == "free"
            && isValidGrigliataBoardPoint(data.point)
            && data.startedAtMs is int
            && data.startedAtMs > 0
          )
        );
    }

    function isValidGrigliataPagePresence(data, presenceId) {
      return data.keys().hasAll([
          "ownerUid",
          "characterId",
          "colorKey",
          "lastSeenAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "ownerUid",
          "characterId",
          "colorKey",
          "lastSeenAt",
          "updatedBy"
        ])
        && data.ownerUid is string
        && data.ownerUid.size() > 0
        && presenceId == data.ownerUid
        && data.characterId is string
        && data.characterId.size() > 0
        && data.colorKey is string
        && isValidGrigliataDrawColorKey(data.colorKey)
        && data.lastSeenAt is timestamp
        && (data.updatedBy == null || data.updatedBy is string);
    }

    function isGrigliataFogOfWarId(backgroundId, ownerUid, fogId) {
      return backgroundId is string
        && backgroundId.size() > 0
        && ownerUid is string
        && ownerUid.size() > 0
        && fogId == backgroundId + "__" + ownerUid;
    }

    function isOwnGrigliataFogOfWarProbeId(fogId) {
      return isSignedIn()
        && fogId is string
        && fogId.matches('^.+__' + request.auth.uid + '$');
    }

    function isOwnGrigliataFogMemoryTileProbeId(tileId) {
      return isSignedIn()
        && tileId is string
        && tileId.matches('^.+__' + request.auth.uid + '__fog-raster-c8-s16-v1__-?[0-9]+:-?[0-9]+$');
    }

    function isValidGrigliataFogCellKey(cellKey) {
      return cellKey is string
        && cellKey.matches('^-?[0-9]+:-?[0-9]+$');
    }

    function hasValidGrigliataFogCellKeys(cells) {
      return cells is list
        && cells.size() <= 5000
        && (cells.size() < 1 || isValidGrigliataFogCellKey(cells[0]))
        && (cells.size() < 2 || isValidGrigliataFogCellKey(cells[1]))
        && (cells.size() < 3 || isValidGrigliataFogCellKey(cells[2]))
        && (cells.size() < 4 || isValidGrigliataFogCellKey(cells[3]))
        && (cells.size() < 5 || isValidGrigliataFogCellKey(cells[4]))
        && (cells.size() < 6 || isValidGrigliataFogCellKey(cells[5]))
        && (cells.size() < 7 || isValidGrigliataFogCellKey(cells[6]))
        && (cells.size() < 8 || isValidGrigliataFogCellKey(cells[7]))
        && (cells.size() < 9 || isValidGrigliataFogCellKey(cells[8]))
        && (cells.size() < 10 || isValidGrigliataFogCellKey(cells[9]))
        && (cells.size() < 11 || isValidGrigliataFogCellKey(cells[10]))
        && (cells.size() < 12 || isValidGrigliataFogCellKey(cells[11]))
        && (cells.size() < 13 || isValidGrigliataFogCellKey(cells[12]))
        && (cells.size() < 14 || isValidGrigliataFogCellKey(cells[13]))
        && (cells.size() < 15 || isValidGrigliataFogCellKey(cells[14]))
        && (cells.size() < 16 || isValidGrigliataFogCellKey(cells[15]))
        && (cells.size() < 17 || isValidGrigliataFogCellKey(cells[16]))
        && (cells.size() < 18 || isValidGrigliataFogCellKey(cells[17]))
        && (cells.size() < 19 || isValidGrigliataFogCellKey(cells[18]))
        && (cells.size() < 20 || isValidGrigliataFogCellKey(cells[19]))
        && (cells.size() < 21 || isValidGrigliataFogCellKey(cells[20]))
        && (cells.size() < 22 || isValidGrigliataFogCellKey(cells[21]))
        && (cells.size() < 23 || isValidGrigliataFogCellKey(cells[22]))
        && (cells.size() < 24 || isValidGrigliataFogCellKey(cells[23]))
        && (cells.size() < 25 || isValidGrigliataFogCellKey(cells[24]))
        && (cells.size() < 26 || isValidGrigliataFogCellKey(cells[25]))
        && (cells.size() < 27 || isValidGrigliataFogCellKey(cells[26]))
        && (cells.size() < 28 || isValidGrigliataFogCellKey(cells[27]))
        && (cells.size() < 29 || isValidGrigliataFogCellKey(cells[28]))
        && (cells.size() < 30 || isValidGrigliataFogCellKey(cells[29]))
        && (cells.size() < 31 || isValidGrigliataFogCellKey(cells[30]))
        && (cells.size() < 32 || isValidGrigliataFogCellKey(cells[31]));
    }

    function hasValidGrigliataFogPolygons(polygons) {
      return polygons is list
        && polygons.size() <= 8;
    }

    function isValidGrigliataFogRasterTileKey(tileKey) {
      return tileKey is string
        && tileKey.matches('^-?[0-9]+:-?[0-9]+$');
    }

    function isGrigliataFogMemoryTileId(backgroundId, ownerUid, rasterProfileId, tileKey, tileId) {
      return backgroundId is string
        && backgroundId.size() > 0
        && ownerUid is string
        && ownerUid.size() > 0
        && rasterProfileId == "fog-raster-c8-s16-v1"
        && isValidGrigliataFogRasterTileKey(tileKey)
        && tileId == backgroundId + "__" + ownerUid + "__" + rasterProfileId + "__" + tileKey;
    }

    function isValidGrigliataFogOfWar(data, fogId) {
      return data.keys().hasAll([
          "backgroundId",
          "ownerUid",
          "cellSizePx",
          "exploredCells",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "schemaVersion",
          "backgroundId",
          "ownerUid",
          "cellSizePx",
          "exploredCells",
          "exploredPolygons",
          "updatedAt",
          "updatedBy"
        ])
        && (!data.keys().hasAny(["schemaVersion"]) || data.schemaVersion is int)
        && isGrigliataFogOfWarId(data.backgroundId, data.ownerUid, fogId)
        && data.cellSizePx is int
        && data.cellSizePx > 0
        && data.cellSizePx <= 500
        && hasValidGrigliataFogCellKeys(data.exploredCells)
        && (!data.keys().hasAny(["exploredPolygons"]) || hasValidGrigliataFogPolygons(data.exploredPolygons))
        && data.updatedAt is timestamp
        && (data.updatedBy == null || data.updatedBy is string);
    }

    function isValidGrigliataFogMemoryTile(data, tileId) {
      return data.keys().hasAll([
          "backgroundId",
          "ownerUid",
          "tileKey",
          "tileCol",
          "tileRow",
          "rasterProfileId",
          "tileSizeCells",
          "samplesPerCell",
          "cellSizePx",
          "offsetXPx",
          "offsetYPx",
          "maskEncoding",
          "maskBase64",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "schemaVersion",
          "backgroundId",
          "ownerUid",
          "tileKey",
          "tileCol",
          "tileRow",
          "rasterProfileId",
          "tileSizeCells",
          "samplesPerCell",
          "cellSizePx",
          "offsetXPx",
          "offsetYPx",
          "maskEncoding",
          "maskBase64",
          "updatedAt",
          "updatedBy"
        ])
        && (!data.keys().hasAny(["schemaVersion"]) || data.schemaVersion is int)
        && isGrigliataFogMemoryTileId(data.backgroundId, data.ownerUid, data.rasterProfileId, data.tileKey, tileId)
        && data.tileCol is int
        && data.tileRow is int
        && data.tileSizeCells == 8
        && data.samplesPerCell == 16
        && data.cellSizePx is int
        && data.cellSizePx > 0
        && data.cellSizePx <= 500
        && data.offsetXPx is int
        && data.offsetYPx is int
        && data.maskEncoding == "base64-bitset-v1"
        && data.maskBase64 is string
        && data.maskBase64.size() <= 4096
        && data.updatedAt is timestamp
        && (data.updatedBy == null || data.updatedBy is string);
    }

    function isValidGrigliataWallRuntimeSegment(segment) {
      return segment is map
        && segment.keys().hasAll([
          "isOpen",
          "updatedAt",
          "updatedBy"
        ])
        && segment.keys().hasOnly([
          "isOpen",
          "updatedAt",
          "updatedBy"
        ])
        && segment.isOpen is bool
        && segment.updatedAt is timestamp
        && (segment.updatedBy == null || segment.updatedBy is string);
    }

    function hasValidGrigliataWallRuntimeSegments(segments, segmentIds) {
      return segments is map
        && segmentIds.size() <= 500
        && (segmentIds.size() < 1 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[0]]))
        && (segmentIds.size() < 2 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[1]]))
        && (segmentIds.size() < 3 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[2]]))
        && (segmentIds.size() < 4 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[3]]))
        && (segmentIds.size() < 5 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[4]]))
        && (segmentIds.size() < 6 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[5]]))
        && (segmentIds.size() < 7 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[6]]))
        && (segmentIds.size() < 8 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[7]]))
        && (segmentIds.size() < 9 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[8]]))
        && (segmentIds.size() < 10 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[9]]))
        && (segmentIds.size() < 11 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[10]]))
        && (segmentIds.size() < 12 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[11]]))
        && (segmentIds.size() < 13 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[12]]))
        && (segmentIds.size() < 14 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[13]]))
        && (segmentIds.size() < 15 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[14]]))
        && (segmentIds.size() < 16 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[15]]))
        && (segmentIds.size() < 17 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[16]]))
        && (segmentIds.size() < 18 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[17]]))
        && (segmentIds.size() < 19 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[18]]))
        && (segmentIds.size() < 20 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[19]]))
        && (segmentIds.size() < 21 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[20]]))
        && (segmentIds.size() < 22 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[21]]))
        && (segmentIds.size() < 23 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[22]]))
        && (segmentIds.size() < 24 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[23]]))
        && (segmentIds.size() < 25 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[24]]))
        && (segmentIds.size() < 26 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[25]]))
        && (segmentIds.size() < 27 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[26]]))
        && (segmentIds.size() < 28 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[27]]))
        && (segmentIds.size() < 29 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[28]]))
        && (segmentIds.size() < 30 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[29]]))
        && (segmentIds.size() < 31 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[30]]))
        && (segmentIds.size() < 32 || isValidGrigliataWallRuntimeSegment(segments[segmentIds[31]]));
    }

    function isValidGrigliataWallRuntimeState(data, backgroundId) {
      return data.keys().hasAll([
          "backgroundId",
          "segments",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "backgroundId",
          "segments",
          "updatedAt",
          "updatedBy"
        ])
        && data.backgroundId == backgroundId
        && hasValidGrigliataWallRuntimeSegments(data.segments, data.segments.keys())
        && data.updatedAt is timestamp
        && (data.updatedBy == null || data.updatedBy is string);
    }

    function isValidGrigliataMusicTrack(data) {
      return data.keys().hasAll([
          "name",
          "fileName",
          "audioUrl",
          "audioPath",
          "contentType",
          "sizeBytes",
          "durationMs",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "name",
          "fileName",
          "audioUrl",
          "audioPath",
          "contentType",
          "sizeBytes",
          "durationMs",
          "musicFolderId",
          "musicFolderAssignedAt",
          "musicFolderAssignedBy",
          "createdAt",
          "createdBy",
          "updatedAt",
          "updatedBy"
        ])
        && data.name is string
        && data.name.size() > 0
        && data.fileName is string
        && data.fileName.size() > 0
        && data.audioUrl is string
        && data.audioUrl.size() > 0
        && data.audioPath is string
        && data.audioPath.matches('^grigliata/music/.+$')
        && data.contentType is string
        && data.contentType.matches('^audio/.+$')
        && data.sizeBytes is int
        && data.sizeBytes >= 0
        && data.durationMs is int
        && data.durationMs > 0
        && (!data.keys().hasAny(["musicFolderId"]) || data.musicFolderId is string)
        && (!data.keys().hasAny(["musicFolderAssignedAt"]) || data.musicFolderAssignedAt == null || data.musicFolderAssignedAt is timestamp)
        && (!data.keys().hasAny(["musicFolderAssignedBy"]) || data.musicFolderAssignedBy == null || data.musicFolderAssignedBy is string)
        && (data.createdBy == null || data.createdBy is string)
        && (data.updatedBy == null || data.updatedBy is string);
    }

    function isValidGrigliataMusicPlaybackStatus(status) {
      return status in ["playing", "paused", "stopped"];
    }

    function isValidGrigliataMusicPlayback(data) {
      return data.keys().hasAll([
          "status",
          "trackId",
          "trackName",
          "audioUrl",
          "durationMs",
          "offsetMs",
          "volume",
          "startedAt",
          "commandId",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "status",
          "trackId",
          "trackName",
          "audioUrl",
          "durationMs",
          "offsetMs",
          "volume",
          "startedAt",
          "commandId",
          "updatedAt",
          "updatedBy"
        ])
        && data.status is string
        && isValidGrigliataMusicPlaybackStatus(data.status)
        && data.trackId is string
        && data.trackName is string
        && data.audioUrl is string
        && data.durationMs is int
        && data.durationMs >= 0
        && data.offsetMs is int
        && data.offsetMs >= 0
        && (data.volume is int || data.volume is float)
        && data.volume >= 0
        && data.volume <= 1
        && data.commandId is string
        && data.commandId.size() > 0
        && (data.updatedBy == null || data.updatedBy is string)
        && (
          (
            data.status == "stopped"
            && data.trackId.size() == 0
            && data.trackName.size() == 0
            && data.audioUrl.size() == 0
            && data.durationMs == 0
            && data.offsetMs == 0
            && data.startedAt == null
          )
          || (
            data.status == "paused"
            && data.trackId.size() > 0
            && data.trackName.size() > 0
            && data.audioUrl.size() > 0
            && data.offsetMs <= data.durationMs
            && data.startedAt == null
          )
          || (
            data.status == "playing"
            && data.trackId.size() > 0
            && data.trackName.size() > 0
            && data.audioUrl.size() > 0
            && data.offsetMs <= data.durationMs
            && data.startedAt != null
          )
        );
    }

    function isValidGrigliataMusicPlaybackSession(data, sessionId) {
      return data.keys().hasAll([
          "status",
          "trackId",
          "trackName",
          "audioUrl",
          "durationMs",
          "offsetMs",
          "loop",
          "startedAt",
          "startedAtMs",
          "commandId",
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "status",
          "trackId",
          "trackName",
          "audioUrl",
          "durationMs",
          "offsetMs",
          "loop",
          "startedAt",
          "startedAtMs",
          "commandId",
          "updatedAt",
          "updatedBy"
        ])
        && data.status is string
        && data.status in ["playing", "paused"]
        && data.trackId is string
        && data.trackId == sessionId
        && data.trackName is string
        && data.trackName.size() > 0
        && data.audioUrl is string
        && data.audioUrl.size() > 0
        && data.durationMs is int
        && data.durationMs > 0
        && data.offsetMs is int
        && data.offsetMs >= 0
        && data.offsetMs <= data.durationMs
        && data.loop is bool
        && data.startedAtMs is int
        && data.startedAtMs >= 0
        && data.commandId is string
        && data.commandId.size() > 0
        && (data.updatedBy == null || data.updatedBy is string)
        && (
          (
            data.status == "paused"
            && data.startedAt == null
            && data.startedAtMs == 0
          )
          || (
            data.status == "playing"
            && data.startedAt != null
            && data.startedAtMs > 0
          )
        );
    }

    function isGrigliataPlacementVisibleToPlayers(data) {
      return !data.keys().hasAny(["isVisibleToPlayers"])
        || data.isVisibleToPlayers == true;
    }

    function isGrigliataPlacementDead(data) {
      return data.keys().hasAny(["isDead"])
        && data.isDead == true;
    }

    function isNpcTextOnlyUpdate() {
      return request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.imagePath == resource.data.imagePath;
    }

    function grigliataCustomTemplateAcceptsInstance(data, tokenId) {
      let role = resolveGrigliataCustomTokenRole(data);
      let templateId = resolveGrigliataCustomTemplateId(data, tokenId);
      return role != "instance"
        || (
          existsAfter(grigliataTokenDocPath(templateId))
          && !isGrigliataTokenPendingDeletion(
            getAfter(grigliataTokenDocPath(templateId)).data
          )
        );
    }

    function grigliataCustomInstanceParentAcceptsMutation(data, tokenId) {
      let role = resolveGrigliataCustomTokenRole(data);
      let templateId = resolveGrigliataCustomTemplateId(data, tokenId);
      return role != "instance"
        || !existsAfter(grigliataTokenDocPath(templateId))
        || !isGrigliataTokenPendingDeletion(
          getAfter(grigliataTokenDocPath(templateId)).data
        );
    }

    function grigliataPlacementTokenAcceptsMutation(data) {
      let tokenId = resolveGrigliataPlacementTokenId(data);
      return tokenId == data.ownerUid
        || (
          existsAfter(grigliataTokenDocPath(tokenId))
          && !isGrigliataTokenPendingDeletion(
            getAfter(grigliataTokenDocPath(tokenId)).data
          )
        );
    }

    function npcPath(npcId) {
      return /databases/$(database)/documents/echi_npcs/$(npcId);
    }

    function referencesPendingNpc(data) {
      let npcId = data is map ? data.get("npcId", "") : "";
      return npcId is string
        && npcId.size() > 0
        && exists(npcPath(npcId))
        && get(npcPath(npcId)).data.get("deletionState", null) == "pending";
    }

    // Encounter helpers
    function encounterPath(encounterId) {
      return /databases/$(database)/documents/encounters/$(encounterId);
    }

    function isEncounterDeletionPending(data) {
      return data is map
        && (
          data.get("deletionState", null) == "pending"
          || data.get("status", null) == "deleted"
        );
    }

    function encounterAcceptsClientMutation(encounterId) {
      return existsAfter(encounterPath(encounterId))
        && !isEncounterDeletionPending(
          getAfter(encounterPath(encounterId)).data
        );
    }

    // Can the authed user read this encounter document (by uid or characterId), excluding deleted ones?
    // Use resource.data when available (reading the encounter doc itself) to avoid extra reads.
    function canReadEncounterDoc() {
      return isSignedIn()
        && resource.data.status != "deleted"
        && (
             (request.auth.uid in resource.data.participantIds)
             || (authedCharacterId() != null
                 && authedCharacterId() in resource.data.participantCharacterIds)
           );
    }

    // Same check when evaluating access from a subcollection (need to get the parent encounter)
    function canReadEncounterById(encounterId) {
      return isSignedIn()
        && exists(encounterPath(encounterId))
        && get(encounterPath(encounterId)).data.status != "deleted"
        && (
             (request.auth.uid in get(encounterPath(encounterId)).data.participantIds)
             || (authedCharacterId() != null
                 && authedCharacterId() in get(encounterPath(encounterId)).data.participantCharacterIds)
           );
    }

    // Users
    match /users/{userId} {
      // Owner read, plus webmaster read. (Note: players cannot read other users.)
      allow read: if isSignedIn() && (request.auth.uid == userId || isWebmaster() || isDM());
      allow create: if isSignedIn() && isSafeOwnerUserCreate(userId);
      allow update: if isSignedIn()
        && (
          isSafeOwnerUserUpdate(userId)
          || isSafePrivilegedUserUpdate(userId)
        );
      allow delete: if false;

      // Dice roll logs subcollection: each user can manage ONLY their own dice rolls
      match /diceRolls/{rollId} {
        // Explicit DM read access keeps dashboard listeners query-friendly; writes stay owner-only.
        allow read: if isSignedIn() && (request.auth.uid == userId || isDM());
        allow write: if isActiveSignedIn() && request.auth.uid == userId;
      }

      // Private map markers per user
      match /map_markers_private/{markerId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isActiveSignedIn()
          && request.auth.uid == userId
          && !referencesPendingNpc(request.resource.data);
        allow update: if isActiveSignedIn()
          && request.auth.uid == userId
          && !referencesPendingNpc(resource.data)
          && !referencesPendingNpc(request.resource.data);
        allow delete: if isActiveSignedIn()
          && request.auth.uid == userId
          && !referencesPendingNpc(resource.data);
      }

      // Task 05 user-data domains. Clients retain the same private audience as
      // the legacy aggregate, while every mutation remains server-owned.
      match /state/{domainId} {
        allow get, list: if canReadPrivateUserDomain(userId)
          && domainId in [
            "progression",
            "resources",
            "settings",
            "equipment",
            "profileContent"
          ];
        allow create, update, delete: if false;
      }

      match /inventory/{inventoryId} {
        allow get, list: if canReadPrivateUserDomain(userId);
        allow create, update, delete: if false;
      }

      match /spells/{contentId} {
        allow get, list: if canReadPrivateUserDomain(userId);
        allow create, update, delete: if false;
      }

      match /tecniche/{contentId} {
        allow get, list: if canReadPrivateUserDomain(userId);
        allow create, update, delete: if false;
      }

      match /content_names/{nameHash} {
        allow read, write: if false;
      }
    }

    match /app_config/user_data_v2 {
      // The operator document contains per-user canary and drain identifiers.
      // Players must use a future privacy-preserving effective-stage resolver;
      // exposing this whole document would reveal every scoped UID.
      allow read: if isDM() || isWebmaster();
      allow write: if false;
    }

    match /app_config/task06_backend {
      // This document controls trigger ownership and enabled destructive or
      // bulk operation kinds. It is observable only to operators and remains
      // server-owned.
      allow read: if isDM() || isWebmaster();
      allow write: if false;
    }

    match /user_operations/{receiptId} {
      allow read, write: if false;
    }

    match /backend_operations/{operationId} {
      // Clients receive a privacy-minimized view through authenticated
      // callables; actor IDs, cursors, inputs, and per-subject receipts stay
      // server-only.
      allow read, write: if false;

      match /subjects/{subjectId} {
        allow read, write: if false;
      }
    }

    match /backend_operation_work/{workId} {
      allow read, write: if false;
    }

    match /user_media_cleanup/{cleanupId} {
      allow read, write: if false;
    }

    match /migration_state/{document=**} {
      allow read, write: if false;
    }

    match /user_deletion_jobs/{jobId} {
      allow read, write: if false;
    }

    // Server-owned, privacy-minimized user lookup records. Authorization is
    // derived from the caller's canonical users/{uid} role, never from the
    // projected document itself.
    match /user_directory/{userId} {
      allow get, list: if isDM() || isWebmaster();
      allow create, update, delete: if false;
    }

    // Items
    match /items/{docId} {
      allow read: if true;
      allow write: if isDM() || isWebmaster();
    }

    match /tecniche/{docId} {
      allow read: if isSignedIn();
      allow write: if isDM() || isWebmaster();
    }

    match /spells/{docId} {
      allow read: if isSignedIn();
      allow write: if isDM() || isWebmaster();
    }

    // Utils
    match /utils/{docId} {
      allow read: if isSignedIn();
      allow write: if isWebmaster() || (isDM() && docId == "codex");
      match /Razze/{raceId} {
        allow read: if isSignedIn();
        allow write: if isWebmaster();
      }
    }

    // Foes
    match /foes/{foeId} {
      allow get, list: if isDM();
      allow create, update, delete: if isDM();
    }

    // Encounters
    match /encounters/{encounterId} {
      // Preserve the existing query-compatible privileged audience. A
      // participant-only read still excludes the server's deleted marker.
      allow read: if isDM()
        || isWebmaster()
        || isPlayer()
        || canReadEncounterDoc();

      // Only the server may publish or advance a deletion fence.
      allow create: if isDM()
        && !isEncounterDeletionPending(request.resource.data);
      allow update: if isDM()
        && !isEncounterDeletionPending(resource.data)
        && !isEncounterDeletionPending(request.resource.data);
      allow delete: if isDM()
        && !isEncounterDeletionPending(resource.data);

      // Per-encounter participants
      match /participants/{pid} {
  // Read: DM, Webmaster, Player (full read like webmaster), or any participant of this encounter
  allow read: if isDM() || isWebmaster() || isPlayer() || canReadEncounterById(encounterId);

        // Create/Update: DM, or the signed-in user updating their own participant doc
        // The participant doc id may be either the user's uid or their characterId; allow both for the owner.
        allow create, update: if encounterAcceptsClientMutation(encounterId)
          && (
            isDM()
          || (
               isActiveSignedIn()
               && canReadEncounterById(encounterId)
               && (pid == request.auth.uid || pid == authedCharacterId())
             )
          );

        // Delete: DM only
        allow delete: if isDM()
          && encounterAcceptsClientMutation(encounterId);
      }

      // Shared logs — OPEN TO ALL SIGNED-IN USERS (any role)
      match /logs/{logId} {
        // Read & Write for any authenticated user; DM still has global allow.
        allow read: if isDM() || isWebmaster() || canReadEncounterById(encounterId);
        allow write: if encounterAcceptsClientMutation(encounterId)
          && (
            isDM()
            || (isActiveSignedIn() && canReadEncounterById(encounterId))
          );
      }
    }

    match /security_audit/{auditId} {
      allow read: if isWebmaster();
      allow write: if false;
    }

    // Map Markers
    match /map_markers/{markerId} {
      allow read: if isSignedIn();
      allow create: if (
          isDM()
          || isWebmaster()
          || isPlayer()
        )
        && !referencesPendingNpc(request.resource.data);
      allow update: if (
          isDM()
          || isWebmaster()
          || isPlayer()
        )
        && !referencesPendingNpc(resource.data)
        && !referencesPendingNpc(request.resource.data);
      allow delete: if (
          isDM()
          || isWebmaster()
          || isPlayer()
        )
        && !referencesPendingNpc(resource.data);
    }

    match /grigliata_state/{stateId} {
      allow read: if isSignedIn();
      allow write: if isGrigliataManager();
    }

    match /grigliata_backgrounds/{backgroundId} {
      allow read: if isSignedIn();
      allow write: if isGrigliataManager();
    }

    match /grigliata_gallery_folders/{folderId} {
      allow read, write: if isGrigliataManager();
    }

    match /grigliata_music_folders/{folderId} {
      allow read, write: if isGrigliataManager();
    }

    match /grigliata_background_lighting/{backgroundId} {
      allow read, write: if isGrigliataManager();
    }

    match /grigliata_lighting_render_inputs/{backgroundId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isGrigliataManager();
    }

    match /grigliata_wall_state/{backgroundId} {
      allow read: if isSignedIn();
      allow create, update: if isGrigliataManager()
        && isValidGrigliataWallRuntimeState(request.resource.data, backgroundId);
      allow delete: if isGrigliataManager();
    }

    match /grigliata_fog_of_war/{fogId} {
      allow get: if isSignedIn()
        && (
          isGrigliataManager()
          || (
            resource == null
            && isOwnGrigliataFogOfWarProbeId(fogId)
          )
          || (
            resource != null
            && request.auth.uid == resource.data.ownerUid
          )
        );

      allow list: if isGrigliataManager();

      allow create: if isActiveSignedIn()
        && isValidGrigliataFogOfWar(request.resource.data, fogId)
        && (
          isGrigliataManager()
          || (
            request.auth.uid == request.resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow update: if isActiveSignedIn()
        && isValidGrigliataFogOfWar(request.resource.data, fogId)
        && request.resource.data.backgroundId == resource.data.backgroundId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          isGrigliataManager()
          || (
            request.auth.uid == resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow delete: if isGrigliataManager();
    }

    match /grigliata_fog_memory_tiles/{tileId} {
      allow get: if isSignedIn()
        && (
          isGrigliataManager()
          || (
            resource == null
            && isOwnGrigliataFogMemoryTileProbeId(tileId)
          )
          || (
            resource != null
            && request.auth.uid == resource.data.ownerUid
          )
        );

      allow list: if isSignedIn()
        && (
          isGrigliataManager()
          || request.auth.uid == resource.data.ownerUid
        );

      allow create: if isActiveSignedIn()
        && isValidGrigliataFogMemoryTile(request.resource.data, tileId)
        && (
          isGrigliataManager()
          || (
            request.auth.uid == request.resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow update: if isActiveSignedIn()
        && isValidGrigliataFogMemoryTile(request.resource.data, tileId)
        && request.resource.data.backgroundId == resource.data.backgroundId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.tileKey == resource.data.tileKey
        && (
          isGrigliataManager()
          || (
            request.auth.uid == resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow delete: if isGrigliataManager();
    }

    match /grigliata_music_tracks/{trackId} {
      allow read: if isGrigliataManager();

      allow create, update: if isGrigliataManager()
        && isValidGrigliataMusicTrack(request.resource.data);

      allow delete: if isGrigliataManager()
        && isValidGrigliataMusicTrack(resource.data);
    }

    match /grigliata_music_playback/{stateId} {
      allow read: if isSignedIn() && stateId == "current";

      allow create, update: if stateId == "current"
        && isGrigliataManager()
        && isValidGrigliataMusicPlayback(request.resource.data);
    }

    match /grigliata_music_playback_sessions/{sessionId} {
      allow read: if isSignedIn();

      allow create, update: if isGrigliataManager()
        && isValidGrigliataMusicPlaybackSession(request.resource.data, sessionId);

      allow delete: if isGrigliataManager()
        && isValidGrigliataMusicPlaybackSession(resource.data, sessionId);
    }

    match /grigliata_tokens/{tokenId} {
      allow read: if isSignedIn()
        && (
          tokenId == resource.data.ownerUid
          || request.auth.uid == resource.data.ownerUid
          || isGrigliataManager()
        );

      allow create: if isActiveSignedIn()
        && isValidGrigliataTokenProfile(request.resource.data, tokenId)
        && grigliataCustomTemplateAcceptsInstance(
          request.resource.data,
          tokenId
        )
        && (
          isGrigliataManager()
          || (
            request.auth.uid == request.resource.data.ownerUid
            && !isGrigliataFoeTokenData(request.resource.data)
            && isOwnerCreatableGrigliataCustomTokenProfile(request.resource.data, tokenId)
          )
        );

      allow update: if isActiveSignedIn()
        && !isGrigliataTokenPendingDeletion(resource.data)
        && grigliataCustomInstanceParentAcceptsMutation(resource.data, tokenId)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          (
            isValidGrigliataTokenProfile(request.resource.data, tokenId)
            && isStableGrigliataCustomTokenContract(request.resource.data, resource.data, tokenId)
            && (
              isGrigliataManager()
              || (
                request.auth.uid == resource.data.ownerUid
                && !isGrigliataFoeTokenData(request.resource.data)
              )
            )
          )
          || (
            isGrigliataManager()
            && isValidLegacyGrigliataTokenScrubUpdate(request.resource.data, resource.data)
          )
        );

      allow delete: if isGrigliataManager()
        && !isGrigliataTokenPendingDeletion(resource.data)
        && grigliataCustomInstanceParentAcceptsMutation(resource.data, tokenId);
    }

    match /grigliata_token_placements/{placementId} {
      allow read: if isSignedIn()
        && (isGrigliataManager() || isGrigliataPlacementVisibleToPlayers(resource.data));

      allow create: if isActiveSignedIn()
        && request.resource.data.keys().hasAll(["tokenId"])
        && isValidGrigliataPlacement(request.resource.data, placementId)
        && grigliataPlacementTokenAcceptsMutation(
          request.resource.data
        )
        && (
          isGrigliataManager()
          || (
            request.auth.uid == request.resource.data.ownerUid
            && isGrigliataPlacementVisibleToPlayers(request.resource.data)
            && !isGrigliataPlacementDead(request.resource.data)
            && !request.resource.data.keys().hasAny([
              "turnCounter",
              "turnEffects",
              "visionEnabled",
              "visionRadiusSquares"
            ])
            && isValidOwnerManagedGrigliataTurnOrderCreate(request.resource.data)
          )
        );

      allow update: if isActiveSignedIn()
        && request.resource.data.keys().hasAll(["tokenId"])
        && isValidGrigliataPlacement(request.resource.data, placementId)
        && grigliataPlacementTokenAcceptsMutation(
          request.resource.data
        )
        && request.resource.data.backgroundId == resource.data.backgroundId
        && request.resource.data.tokenId == resolveGrigliataPlacementTokenId(resource.data)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          isGrigliataManager()
          || (
            request.auth.uid == resource.data.ownerUid
            && isGrigliataPlacementVisibleToPlayers(resource.data)
            && isGrigliataPlacementVisibleToPlayers(request.resource.data)
            && isGrigliataPlacementDead(request.resource.data) == isGrigliataPlacementDead(resource.data)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              "turnCounter",
              "turnEffects",
              "visionEnabled",
              "visionRadiusSquares"
            ])
            && isValidOwnerManagedGrigliataTurnOrderUpdate(request.resource.data, resource.data)
          )
        );

      allow delete: if isActiveSignedIn()
        && isValidGrigliataPlacement(resource.data, placementId)
        && (
          isGrigliataManager()
          || (
            request.auth.uid == resource.data.ownerUid
            && isGrigliataPlacementVisibleToPlayers(resource.data)
          )
        );
    }

    match /grigliata_live_interactions/{interactionId} {
      allow read: if isSignedIn();

      allow create: if isActiveSignedIn()
        && isValidGrigliataLiveInteraction(request.resource.data, interactionId)
        && (
          isGrigliataManager()
          || (
            request.auth.uid == request.resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow update: if isActiveSignedIn()
        && isValidGrigliataLiveInteraction(request.resource.data, interactionId)
        && request.resource.data.backgroundId == resource.data.backgroundId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          isGrigliataManager()
          || (
            request.auth.uid == resource.data.ownerUid
            && (
              request.resource.data.updatedBy == null
              || request.resource.data.updatedBy == request.auth.uid
            )
          )
        );

      allow delete: if isActiveSignedIn()
        && isValidGrigliataLiveInteraction(resource.data, interactionId)
        && (
          isGrigliataManager()
          || request.auth.uid == resource.data.ownerUid
        );
    }

    match /grigliata_page_presence/{presenceId} {
      allow read: if isSignedIn();

      allow create, update: if isActiveSignedIn()
        && !isGrigliataManager()
        && isValidGrigliataPagePresence(request.resource.data, presenceId)
        && request.auth.uid == request.resource.data.ownerUid
        && (
          request.resource.data.updatedBy == null
          || request.resource.data.updatedBy == request.auth.uid
        );

      allow delete: if isActiveSignedIn()
        && !isGrigliataManager()
        && isValidGrigliataPagePresence(resource.data, presenceId)
        && request.auth.uid == resource.data.ownerUid;
    }

    match /grigliata_aoe_figures/{figureId} {
      allow read: if isSignedIn()
        && (
          isGrigliataManager()
          || (
            resource == null
            && isOwnGrigliataAoEFigureProbeId(figureId)
          )
          || (
            resource != null
            && (
              request.auth.uid == resource.data.ownerUid
              || resource.data.isVisibleToPlayers == true
            )
          )
        );

      allow create: if isActiveSignedIn()
        && isValidGrigliataAoEFigure(request.resource.data, figureId)
        && (
          isGrigliataManager()
          || request.auth.uid == request.resource.data.ownerUid
        );

      allow update: if isActiveSignedIn()
        && isValidGrigliataAoEFigure(request.resource.data, figureId)
        && request.resource.data.backgroundId == resource.data.backgroundId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.figureType == resource.data.figureType
        && request.resource.data.slot == resource.data.slot
        && (
          isGrigliataManager()
          || request.auth.uid == resource.data.ownerUid
        );

      allow delete: if isActiveSignedIn()
        && isValidGrigliataAoEFigure(resource.data, figureId)
        && (
          isGrigliataManager()
          || request.auth.uid == resource.data.ownerUid
        );
    }

    // Echi NPCs
    match /echi_npcs/{npcId} {
      allow read: if isSignedIn();

      allow create: if (isDM() || isWebmaster())
        && request.resource.data.keys().hasAll([
          "nome",
          "imageUrl",
          "imagePath",
          "description",
          "notes",
          "createdBy",
          "createdByRole",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "nome",
          "imageUrl",
          "imagePath",
          "description",
          "notes",
          "createdBy",
          "createdByRole",
          "createdAt",
          "updatedAt"
        ]);

      // Text-only updates: immutable image + creator metadata
      allow update: if isActiveSignedIn()
        && request.resource.data.keys().hasAll([
          "nome",
          "imageUrl",
          "imagePath",
          "description",
          "notes",
          "createdBy",
          "createdByRole",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.imagePath == resource.data.imagePath
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByRole == resource.data.createdByRole
        && request.resource.data.createdAt == resource.data.createdAt
        && (isNpcTextOnlyUpdate() || isDM() || isWebmaster())
        && request.resource.data.keys().hasOnly([
          "nome",
          "imageUrl",
          "imagePath",
          "description",
          "notes",
          "createdBy",
          "createdByRole",
          "createdAt",
          "updatedAt"
        ]);

      allow delete: if (isDM() || isWebmaster())
        && resource.data.get("deletionState", null) != "pending";
    }
  }
}
